{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"content":[{"level":2,"anchor":"%D0%9E%D0%B1%D0%B7%D0%BE%D1%80","text":"Обзор","type":"heading"},{"inlineContent":[{"type":"text","text":"В процессе работы карта изменяет состояние, как вследствии запрограммированной в SDK логики (загрузка карты и стилей, смена режимов следования), действий пользователя (жесты, взаимодействие с маркерами), так и вследствии вызовов методов "},{"type":"codeVoice","code":"flyTo"},{"type":"text","text":", "},{"type":"codeVoice","code":"setBearing"},{"type":"text","text":" и других. Используя делегат карты вы можете реагировать на изменение состояния, отслеживая следующие события:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"карты отображена на экране;"}]}]},{"content":[{"inlineContent":[{"text":"стиль загружен;","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"камера перемещена;"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"нажатие на маркер;","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"нажатие на карте;"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"долгое нажатие на карту;","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"смена режима следования;"}]}]},{"content":[{"inlineContent":[{"text":"различные ошибки.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"style":"tip","content":[{"inlineContent":[{"text":"Процесс создания делегата карты описан в статье ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/StartUsing","type":"reference","isActive":true}],"type":"paragraph"}],"name":"Tip","type":"aside"},{"level":3,"anchor":"%D0%9C%D0%B5%D1%82%D0%BE%D0%B4%D1%8B-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","text":"Методы делегата","type":"heading"},{"inlin