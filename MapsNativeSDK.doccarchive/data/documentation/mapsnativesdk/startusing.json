":"%D0%A8%D0%B0%D0%B3-3-%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D1%83%D0%B9%D1%82%D0%B5-MapsNativeSDK","text":"Шаг 3. Используйте MapsNativeSDK","type":"heading"},{"level":3,"anchor":"%D0%98%D0%BC%D0%BF%D0%BE%D1%80%D1%82-SDK","text":"Импорт SDK","type":"heading"},{"inlineContent":[{"type":"text","text":"Импортируйте "},{"type":"codeVoice","code":"MapsNativeSDK"},{"type":"text","text":" в файл, в котором вы будете использовать карту."}],"type":"paragraph"},{"code":["import MapsNativeSDK"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-SDK","text":"Конфигурация SDK","type":"heading"},{"inlineContent":[{"text":"Сконфигурируйте SDK, используя метод ","type":"text"},{"code":"MapsSDKConfigurator\/setup(baseURL:apiKey:diskCachePath:maxCacheSizeBytes:fileTimeoutSec:)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ Конфигурация с передачей только API-ключа","MapsSDKConfigurator.setup(apiKey: ##API-ключ##)","","\/\/ Конфигурация с передачей дополнительных параметров","MapsSDKConfigurator.setup(baseURL: ##Базовый URL для загрузки тайлов и предустановленных стиле##,","                          apiKey: ##API-ключ##,","                          diskCachePath: ##Путь для хранения файлов кэша на диске##,","                          maxCacheSizeBytes: ##Максимальный размер файлового кэша в байтах##,","                          fileTimeoutSec: ## Время жизни файлов в кэше ###)"],"syntax":"swift","type":"codeListing"},{"name":"Important","content":[{"inlineContent":[{"text":"Если не указать путь к файловому кэшу, то SDK не будет кешировать данные в виде файлов.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important"},{"level":3,"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-%D0%BA%D0%B0%D1%80%D1%82%D1%8B","text":"Конфигурация карты","type":"heading"},{"inlineContent":[{"type":"text","text":"Создайте конфигурацию для карты с помощью типа "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration"},{"type":"text","text":", указав исходные настройки карты."}],"type":"paragraph"},{"code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","isActive":true},{"type":"text","text":" или строку в формате JSON (подробнее в статье "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"level":3,"anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","text":"Создание делегата","type":"heading"},{"inlineContent":[{"text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle"},{"text":"). При создании делегата подпишитесь на протокол ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView"},{"type":"text","text":"."}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"text":"Не требуется реализовывать методы ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"text":", если их функциональность вам не нужна.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"level":3,"anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","text":"Размещение карт на экране","type":"heading"},{"inlineContent":[{"text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ.","type":"text"}],"type":"paragraph"},{"name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова ","type":"text"},{"code":"MapsSDKConfigurator.setup","type":"codeVoice"},{"text":".","type":"text"}]}],"type":"aside","style":"warning"},{"level":4,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в UIKit-проекте","type":"heading"},{"inlineContent":[{"type":"text","text":"Для использования карты в UIKit необходимо создать объект "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView"},{"type":"text","text":", передав в него конфигурацию, и разместить созданный объект на экране."}],"type":"paragraph"},{"code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"],"syntax":"swift","type":"codeListing"},{"level":4,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в SwiftUI-проекте","type":"heading"},{"inlineContent":[{"text":"Для использования карты в SwiftUI необходимо создать объект ","type":"text"},{"type":"codeVoice","code":"MapView"},{"text":" и передать его в структуру ","type":"text"},{"type":"codeVoice","code":"Map"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"article","metadata":{"modules":[{"name":"MapsNativeSDK"}],"title":"Начало работы с MapsNativeSDK","role":"article","roleHeading":"Article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapsnativesdk\/startusing"]}],"references":{"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapConfiguration":{"url":"\/documentation\/mapsnativesdk\/mapconfiguration","title":"MapConfiguration","navigatorTitle":[{"text":"MapConfiguration","kind":"identifier"}],"abstract":[{"text":"Configuration of Map","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MapConfiguration","kind":"identifier"}],"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapViewDelegate":{"kind":"symbol","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","role":"symbol","url":"\/documentation\/mapsnativesdk\/mapviewdelegate","abstract":[{"type":"text","text":"Interface, that MapView uses to inform its delegate about events on map"}],"navigatorTitle":[{"text":"MapViewDelegate","kind":"identifier"}],"title":"MapViewDelegate","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MapViewDelegate","kind":"identifier"}],"type":"topic"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/Lifecycle":{"type":"to