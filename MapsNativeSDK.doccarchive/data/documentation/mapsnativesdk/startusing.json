,"level":2,"text":"Шаг 3. Используйте MapsNativeSDK"},{"anchor":"%D0%98%D0%BC%D0%BF%D0%BE%D1%80%D1%82-SDK","type":"heading","level":3,"text":"Импорт SDK"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Импортируйте "},{"code":"MapsNativeSDK","type":"codeVoice"},{"type":"text","text":" в файл, в котором вы будете использовать карту."}]},{"syntax":"swift","code":["import MapsNativeSDK"],"type":"codeListing"},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-SDK","type":"heading","level":3,"text":"Конфигурация SDK"},{"type":"paragraph","inlineContent":[{"text":"Сконфигурируйте SDK, используя метод ","type":"text"},{"type":"codeVoice","code":"MapsSDKConfigurator\/setup(baseURL:apiKey:diskCachePath:maxCacheSizeBytes:fileTimeoutSec:)"},{"text":".","type":"text"}]},{"syntax":"swift","code":["\/\/ Конфигурация с передачей только API-ключа","MapsSDKConfigurator.setup(apiKey: ##API-ключ##)","","\/\/ Конфигурация с передачей дополнительных параметров","MapsSDKConfigurator.setup(baseURL: ##Базовый URL для загрузки тайлов и предустановленных стиле##,","                          apiKey: ##API-ключ##,","                          diskCachePath: ##Путь для хранения файлов кэша на диске##,","                          maxCacheSizeBytes: ##Максимальный размер файлового кэша в байтах##,","                          fileTimeoutSec: ## Время жизни файлов в кэше ###)"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"Если не указать путь к файловому кэшу, то SDK не будет кешировать данные в виде файлов."}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-%D0%BA%D0%B0%D1%80%D1%82%D1%8B","type":"heading","level":3,"text":"Конфигурация карты"},{"type":"paragraph","inlineContent":[{"text":"Создайте конфигурацию для карты с помощью типа ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration","type":"reference","isActive":true},{"text":", указав исходные настройки карты.","type":"text"}]},{"syntax":"swift","code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle"},{"type":"text","text":" или строку в формате JSON (подробнее в статье "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles"},{"type":"text","text":")."}]},{"anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","type":"heading","level":3,"text":"Создание делегата"},{"type":"paragraph","inlineContent":[{"text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle","type":"reference","isActive":true},{"text":"). При создании делегата подпишитесь на протокол ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","type":"reference","isActive":true},{"text":".","type":"text"}]},{"syntax":"swift","code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа ","type":"text"},{"isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","type":"reference"},{"text":".","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"Не требуется реализовывать методы "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","type":"reference","isActive":true},{"type":"text","text":", если их функциональность вам не нужна."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","type":"heading","level":3,"text":"Размещение карт на экране"},{"type":"paragraph","inlineContent":[{"text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова "},{"type":"codeVoice","code":"MapsSDKConfigurator.setup"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside","style":"warning","name":"Warning"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","type":"heading","level":4,"text":"Использование в UIKit-проекте"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для использования карты в UIKit необходимо создать объект "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","type":"reference","isActive":true},{"type":"text","text":", передав в него конфигурацию, и разместить созданный объект на экране."}]},{"syntax":"swift","code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"],"type":"codeListing"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","type":"heading","level":4,"text":"Использование в SwiftUI-проекте"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для использования карты в SwiftUI необходимо создать объект "},{"type":"codeVoice","code":"MapView"},{"type":"text","text":" и передать его в структуру "},{"type":"codeVoice","code":"Map"},{"type":"text","text":"."}]},{"syntax":"swift","code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"],"type":"codeListing"}],"kind":"content"}],"identifier":{"url":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/StartUsing","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK"]]},"variants":[{"paths":["\/documentation\/mapsnativesdk\/startusing"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"MapsNativeSDK"}],"role":"article","title":"Начало работы с MapsNativeSDK"},"references":{"doc://MapsNativeSDK/documentation/MapsNativeSDK/Styles":{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","kind":"article","type":"topic","url":"\/documentation\/mapsnativesdk\/styles","abstract":[{"type":"text","text":"Изменяйте внешний вид карты, рисуйте геометрические фигуры и размещайте маркеры."}],"role":"article","title":"Оформление карты"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapConfiguration":{"url":"\/documentation\/mapsnativesdk\/mapconfiguration","kind":"symbol","abstract":[{"type":"text","text":"Configuration of Map"}],"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration","title":"MapConfiguration","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MapConfiguration","kind":"identifier"}],"navigatorTitle":[{"text":"MapConfiguration","kind":"identifier"}]},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapViewDelegate":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MapViewDelegate"}],"navigatorTitle":[{"kind":"identifier","text":"MapVie