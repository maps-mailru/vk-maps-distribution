sNativeSDK\/MapViewDelegate","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","isActive":true},{"type":"text","text":"."}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Не требуется реализовывать методы "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"type":"text","text":", если их функциональность вам не нужна."}]}]},{"type":"heading","level":3,"text":"Размещение карт на экране","anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ."}]},{"type":"aside","name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова ","type":"text"},{"code":"MapsSDKConfigurator.setup","type":"codeVoice"},{"text":".","type":"text"}]}]},{"type":"heading","level":4,"text":"Использование в UIKit-проекте","anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5"},{"type":"paragraph","inlineContent":[{"text":"Для использования карты в UIKit необходимо создать объект ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView"},{"text":", передав в него конфигурацию, и разместить созданный объект на экране.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"]},{"type":"heading","level":4,"text":"Использование в SwiftUI-проекте","anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для использования карты в SwiftUI необходимо создать объект "},{"type":"codeVoice","code":"MapView"},{"type":"text","text":" и передать его в структуру "},{"type":"codeVoice","code":"Map"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"]}],"kind":"content"}],"references":{"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapView":{"url":"\/documentation\/mapsnativesdk\/mapview","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MapView"}],"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MapView"}],"abstract":[{"type":"text","text":"Main object of the Map"}],"title":"MapView","type":"topic"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/Styles":{"role":"article","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","abstract":[{"text":"Изменяйте внешний вид карты, рисуйте геометрические фигуры и размещайте маркеры.","type":"text"}],"title":"Оформление карты","type":"topic","kind":"article","url":"\/documentation\/mapsnativesdk\/styles"},"https://dev.vk.com/ru/vkmaps/general-information/api-key":{"identifier":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","type":"link","title":"портале","titleInlineContent":[{"text":"портале","type":"text"}],"url":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key"},"addedFrameworks":{"type":"image