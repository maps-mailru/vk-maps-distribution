ет кешировать данные в виде файлов."}],"type":"paragraph"}]},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-%D0%BA%D0%B0%D1%80%D1%82%D1%8B","text":"Конфигурация карты","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Создайте конфигурацию для карты с помощью типа ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration","type":"reference","isActive":true},{"text":", указав исходные настройки карты.","type":"text"}]},{"code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа ","type":"text"},{"isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","type":"reference"},{"text":" или строку в формате JSON (подробнее в статье ","type":"text"},{"isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","type":"reference"},{"text":").","type":"text"}]},{"anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","text":"Создание делегата","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle"},{"type":"text","text":"). При создании делегата подпишитесь на протокол "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"type":"text","text":"."}]},{"code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","type":"reference","isActive":true},{"text":".","type":"text"}]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Не требуется реализовывать методы "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"type":"text","text":", если их функциональность вам не нужна."}],"type":"paragraph"}]},{"anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","text":"Размещение карт на экране","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ.","type":"text"}]},{"style":"warning","name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова ","type":"text"},{"code":"MapsSDKConfigurator.setup","type":"codeVoice"},{"text":".","type":"text"}]}]},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в UIKit-проекте","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для использования карты в UIKit необходимо создать объект "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","type":"reference","isActive":true},{"type":"text","text":", передав в него конфигурацию, и разместить созданный объект на экране."}]},{"code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"],"type":"codeListing","syntax":"swift"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в SwiftUI-проекте","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"text":"Для использования карты в SwiftUI необходимо создать объект ","type":"text"},{"code":"MapView","type":"codeVoice"},{"text":" и передать его в структуру ","type":"text"},{"code":"Map","type":"codeVoice"},{"text":".","type":"text"}]},{"code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapsnativesdk\/startusing"]}],"references":{"https://dev.vk.com/ru/vkmaps/general-information/api-key":{"titleInlineContent":[{"text":"портале","type":"text"}],"identifier":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","type":"link","url":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","title":"портале"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapConfiguration":{"title":"MapConfiguration","abstract":[{"type":"text","text":"Configuration of Map"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MapConfiguration"}],"role":"symbol","type":"topic","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MapConfiguration"}],"url":"\/documentation\/mapsnativesdk\/mapconfiguration"},"doc://MapsNativeSDK/documentation/MapsNativeSDK":{"type":"topic","kind":"symbol","title":"MapsNativeSDK","role":"collection","abstract":[{"inlineContent":[{"type":"text","text":"MapsNativeSDK"}],"type":"strong"},{"type":"text","text":" - библиотека, позволяющая использовать картографические данные и геосервисы VK в ваших iOS-приложениях."}],"identifier