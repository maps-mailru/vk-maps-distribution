K\/MapConfiguration","type":"reference"},{"text":", указав исходные настройки карты.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle"},{"text":" или строку в формате JSON (подробнее в статье ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles"},{"text":").","type":"text"}],"type":"paragraph"},{"level":3,"text":"Создание делегата","anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","type":"heading"},{"inlineContent":[{"text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle","type":"reference","isActive":true},{"text":"). При создании делегата подпишитесь на протокол ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"Не требуется реализовывать методы "},{"isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","type":"reference"},{"type":"text","text":", если их функциональность вам не нужна."}],"type":"paragraph"}],"name":"Note","style":"note"},{"type":"heading","anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","level":3,"text":"Размещение карт на экране"},{"type":"paragraph","inlineContent":[{"text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ.","type":"text"}]},{"type":"aside","content":[{"inlineContent":[{"text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова ","type":"text"},{"code":"MapsSDKConfigurator.setup","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"Warning","style":"warning"},{"type":"heading","anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","level":4,"text":"Использование в UIKit-проекте"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для использования карты в UIKit необходимо создать объект "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView"},{"type":"text","text":", передав в него конфигурацию, и разместить созданный объект на экране."}]},{"type":"codeListing","syntax":"swift","code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"]},{"type":"heading","anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","level":4,"text":"Использование в SwiftUI-проекте"},{"type":"paragraph","inlineContent":[{"text":"Для использования карты в SwiftUI необходимо создать объект ","type":"text"},{"type":"codeVoice","code":"MapView"},{"text":" и передать его в структуру ","type":"text"},{"type":"codeVoice","code":"Map"},{"text":".","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"]}]}],"metadata":{"title":"Начало работы с MapsNativeSDK","roleHeading":"Article","modules":[{"name":"MapsNativeSDK"}],"role":"article"},"kind":"article","variants":[{"paths":["\/documentation\/mapsnativesdk\/startusing"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK"]]},"identifier":{"url":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/StartUsing","interfaceLanguage":"swift"},"sections":[],"references":{"https://dev.vk.com/ru/vkmaps/general-information/api-key":{"type":"link","titleInlineContent":[{"text":"портале","type":"text"}],"identifier":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","url":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","title":"портале"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapStyle":{"title":"MapStyle","navigatorTitle":[{"text":"MapStyle","kind":"identifier"}],"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MapStyle","kind":"identifier"}],"url":"\/documentation\/mapsnativesdk\/mapstyle","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Controller for managing map style: sources, layers, and runtime images\/models."}],"role":"symbol"},"doc://MapsNativeSDK/documentation/MapsNativeSDK":{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK","type":"topic","abstract":[{"inlineContent":[{"type":"text","text":"MapsNativeSDK"}],"type":"strong"},{"text":" - библиотека, позволяющая использовать картографические данные и геосервисы VK в ваших iOS-приложениях.","type":"t