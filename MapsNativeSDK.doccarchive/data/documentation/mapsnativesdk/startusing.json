е "},{"type":"codeVoice","code":".xcframework"},{"type":"text","text":"-файлы в раздел "},{"code":"Frameworks, Libraries, and Embedded Content","type":"codeVoice"},{"type":"text","text":". На скриншоте ниже показан пример добавленных фреймворков в target."}]}]}],"type":"orderedList"},{"inlineContent":[{"identifier":"addedFrameworks","type":"image"}],"type":"paragraph"},{"anchor":"%D0%A8%D0%B0%D0%B3-3-%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D1%83%D0%B9%D1%82%D0%B5-MapsNativeSDK","text":"Шаг 3. Используйте MapsNativeSDK","level":2,"type":"heading"},{"anchor":"%D0%98%D0%BC%D0%BF%D0%BE%D1%80%D1%82-SDK","level":3,"text":"Импорт SDK","type":"heading"},{"inlineContent":[{"text":"Импортируйте ","type":"text"},{"code":"MapsNativeSDK","type":"codeVoice"},{"text":" в файл, в котором вы будете использовать карту.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import MapsNativeSDK"],"type":"codeListing"},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-SDK","text":"Конфигурация SDK","level":3,"type":"heading"},{"inlineContent":[{"text":"Сконфигурируйте SDK, используя метод ","type":"text"},{"type":"codeVoice","code":"MapsSDKConfigurator\/setup(baseURL:apiKey:diskCachePath:maxCacheSizeBytes:fileTimeoutSec:)"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Конфигурация с передачей только API-ключа","MapsSDKConfigurator.setup(apiKey: ##API-ключ##)","","\/\/ Конфигурация с передачей дополнительных параметров","MapsSDKConfigurator.setup(baseURL: ##Базовый URL для загрузки тайлов и предустановленных стиле##,","                          apiKey: ##API-ключ##,","                          diskCachePath: ##Путь для хранения файлов кэша на диске##,","                          maxCacheSizeBytes: ##Максимальный размер файлового кэша в байтах##,","                          fileTimeoutSec: ## Время жизни файлов в кэше ###)"],"type":"codeListing"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Если не указать путь к файловому кэшу, то SDK не будет кешировать данные в виде файлов.","type":"text"}]}],"name":"Important","type":"aside"},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-%D0%BA%D0%B0%D1%80%D1%82%D1%8B","text":"Конфигурация карты","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Создайте конфигурацию для карты с помощью типа "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration","isActive":true},{"type":"text","text":", указав исходные настройки карты."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","isActive":true},{"type":"text","text":" или строку в формате JSON (подробнее в статье "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","text":"Создание делегата","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle","isActive":true},{"type":"text","text":"). При создании делегата подпишитесь на протокол "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Не требуется реализовывать методы ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"text":", если их функциональность вам не нужна.","type":"text"}]}],"name":"Note","type":"aside"},{"anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","text":"Размещение карт на экране","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ."}],"type":"paragraph"},{"style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова ","type":"text"},{"code":"MapsSDKConfigurator.setup","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"Warning","type":"aside"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в UIKit-проекте","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"Для использования карты в UIKit необходимо создать объект "},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","isActive":true},{"type":"text","text":", передав в него конфигурацию, и разместить созданный объект на экране."}],"type":"paragraph"},{"syntax":"swift","code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"],"type":"codeListing"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в SwiftUI-проекте","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"Для использования карты в SwiftUI необходимо создать объект "},{"type":"codeVoice","code":"MapView"},{"type":"text","text":" и передать его в структуру "},{"type":"codeVoice","code":"Map"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"],"type":"codeListing"}]}],"sections":[],"references":{"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapViewDelegate":{"abstract":[{"text":"Interface, that MapView uses to inform its delegate about events on map","type":"text"}],"type":"topic","url":"\/documentation\/mapsnativesdk\/mapviewdelegate","role":"symbol","title":"MapViewDelegate","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","navigatorTitle":[{"kind":"identifier","text":"MapViewDelegate"}],"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MapViewDelegate","kind":"identifier"}]},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapStyle":{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Controller for managing map style: sources, layers, and runtime images\/models."}],"navigatorTitle":[{"kind":"identifier","text":"MapStyle"}],"url":"\/documentation\/mapsnativesdk\/mapstyle","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MapStyle"}],"kind":"symbol","title":"MapStyle"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/Lifecycle":