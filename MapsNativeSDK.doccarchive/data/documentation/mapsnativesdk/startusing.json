mentation\/MapsNativeSDK\/MapConfiguration"},{"text":", указав исходные настройки карты.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"]},{"inlineContent":[{"type":"text","text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","type":"reference","isActive":true},{"type":"text","text":" или строку в формате JSON (подробнее в статье "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","type":"reference","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"level":3,"anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","text":"Создание делегата","type":"heading"},{"inlineContent":[{"type":"text","text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle"},{"type":"text","text":"). При создании делегата подпишитесь на протокол "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"]},{"inlineContent":[{"type":"text","text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Не требуется реализовывать методы ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","type":"reference","isActive":true},{"text":", если их функциональность вам не нужна.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"level":3,"anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","text":"Размещение карт на экране","type":"heading"},{"inlineContent":[{"type":"text","text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова ","type":"text"},{"type":"codeVoice","code":"MapsSDKConfigurator.setup"},{"text":".","type":"text"}]}],"name":"Warning","type":"aside","style":"warning"},{"level":4,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в UIKit-проекте","type":"heading"},{"inlineContent":[{"text":"Для использования карты в UIKit необходимо создать объект ","type":"text"},{"isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","type":"reference"},{"text":", передав в него конфигурацию, и разместить созданный объект на экране.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"]},{"level":4,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","text":"Использование в SwiftUI-проекте","type":"heading"},{"inlineContent":[{"type":"text","text":"Для использования карты в SwiftUI необходимо создать объект "},{"type":"codeVoice","code":"MapView"},{"type":"text","text":" и передать его в структуру "},{"type":"codeVoice","code":"Map"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"]}],"kind":"content"}],"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Интегрируйте карты в свое приложение на основе UIKit или SwiftUI.","type":"text"}],"metadata":{"modules":[{"name":"MapsNativeSDK"}],"roleHeading":"Article","role":"article","title":"Начало работы с MapsNativeSDK"},"hierarchy":{"paths":[["doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/StartUsing"},"references":{"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapStyle":{"role":"symbol","url":"\/documentation\/mapsnativesdk\/mapstyle","abstract":[{"text":"Controller for managing map style: sources, layers, and runtime images\/models.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","type":"topic","title":"MapStyle","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MapStyle","kind":"identifier"}],"navigatorTitle":[{"text":"MapStyle","kind":"identifier"}]},"https://dev.vk.com/ru/vkmaps/general-information/api-key":{"identifier":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","title":"портале","titleInlineContent":[{"type":"text","text":"портале"}],"url":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","type":"link"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapConfiguration":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MapConfiguration"}],"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MapConfiguration"}],"identifier":"doc:\/\/MapsNativeSDK\/documentation\/Ma