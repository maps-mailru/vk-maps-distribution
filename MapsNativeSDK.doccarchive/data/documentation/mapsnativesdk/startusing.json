e","code":"Frameworks, Libraries, and Embedded Content"},{"text":". На скриншоте ниже показан пример добавленных фреймворков в target.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"addedFrameworks","type":"image"}]},{"anchor":"%D0%A8%D0%B0%D0%B3-3-%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D1%83%D0%B9%D1%82%D0%B5-MapsNativeSDK","type":"heading","level":2,"text":"Шаг 3. Используйте MapsNativeSDK"},{"anchor":"%D0%98%D0%BC%D0%BF%D0%BE%D1%80%D1%82-SDK","type":"heading","level":3,"text":"Импорт SDK"},{"type":"paragraph","inlineContent":[{"text":"Импортируйте ","type":"text"},{"code":"MapsNativeSDK","type":"codeVoice"},{"text":" в файл, в котором вы будете использовать карту.","type":"text"}]},{"code":["import MapsNativeSDK"],"type":"codeListing","syntax":"swift"},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-SDK","type":"heading","level":3,"text":"Конфигурация SDK"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Сконфигурируйте SDK, используя метод "},{"type":"codeVoice","code":"MapsSDKConfigurator\/setup(baseURL:apiKey:diskCachePath:maxCacheSizeBytes:fileTimeoutSec:)"},{"type":"text","text":"."}]},{"code":["\/\/ Конфигурация с передачей только API-ключа","MapsSDKConfigurator.setup(apiKey: ##API-ключ##)","","\/\/ Конфигурация с передачей дополнительных параметров","MapsSDKConfigurator.setup(baseURL: ##Базовый URL для загрузки тайлов и предустановленных стиле##,","                          apiKey: ##API-ключ##,","                          diskCachePath: ##Путь для хранения файлов кэша на диске##,","                          maxCacheSizeBytes: ##Максимальный размер файлового кэша в байтах##,","                          fileTimeoutSec: ## Время жизни файлов в кэше ###)"],"type":"codeListing","syntax":"swift"},{"type":"aside","style":"important","content":[{"inlineContent":[{"type":"text","text":"Если не указать путь к файловому кэшу, то SDK не будет кешировать данные в виде файлов."}],"type":"paragraph"}],"name":"Important"},{"anchor":"%D0%9A%D0%BE%D0%BD%D1%84%D0%B8%D0%B3%D1%83%D1%80%D0%B0%D1%86%D0%B8%D1%8F-%D0%BA%D0%B0%D1%80%D1%82%D1%8B","type":"heading","level":3,"text":"Конфигурация карты"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Создайте конфигурацию для карты с помощью типа "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapConfiguration","isActive":true,"type":"reference"},{"type":"text","text":", указав исходные настройки карты."}]},{"code":["\/\/ Кофигурация для карты с использованием предустановленного стиля","let configuration = MapConfiguration(","    center: ##Стартовые координаты центра карты##,","    zoom: ##Стартовый зум карты##,","    predefinedStyle: .simple",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Вместо предустановленных стилей вы можете передать стиль, загруженный с помощью типа ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapStyle","type":"reference","isActive":true},{"text":" или строку в формате JSON (подробнее в статье ","type":"text"},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","type":"reference","isActive":true},{"text":").","type":"text"}]},{"anchor":"%D0%A1%D0%BE%D0%B7%D0%B4%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B4%D0%B5%D0%BB%D0%B5%D0%B3%D0%B0%D1%82%D0%B0","type":"heading","level":3,"text":"Создание делегата"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Вам необходимо создать объект-делегат карты, в котором в дальнейшем вы сможете обрабатывать события жизненного цикла карты (подробнее в статье "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle","type":"reference","isActive":true},{"type":"text","text":"). При создании делегата подпишитесь на протокол "},{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","type":"reference","isActive":true},{"type":"text","text":"."}]},{"code":["\/\/ Определение класса-делегата","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ ...","","\/\/ Создание делегата","let delegate = BaseMapViewDelegate()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"В дальнейшем данный объект потребуется передать при создании экземпляра типа "},{"isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView","type":"reference"},{"type":"text","text":"."}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Не требуется реализовывать методы ","type":"text"},{"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapViewDelegate","isActive":true},{"text":", если их функциональность вам не нужна.","type":"text"}]}],"name":"Note"},{"anchor":"%D0%A0%D0%B0%D0%B7%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D1%80%D1%82-%D0%BD%D0%B0-%D1%8D%D0%BA%D1%80%D0%B0%D0%BD%D0%B5","type":"heading","level":3,"text":"Размещение карт на экране"},{"type":"paragraph","inlineContent":[{"text":"MapsNativeSDK могут быть использованы в приложениях, основанных на UIKit и SwiftUI. Далее рассмотрим каждую из платформ.","type":"text"}]},{"type":"aside","style":"warning","content":[{"inlineContent":[{"type":"text","text":"Убедитесь, что к этому моменту вы сконфигурировали SDK с помощью вызова "},{"type":"codeVoice","code":"MapsSDKConfigurator.setup"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Warning"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","type":"heading","level":4,"text":"Использование в UIKit-проекте"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для использования карты в UIKit необходимо создать объект "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView"},{"type":"text","text":", передав в него конфигурацию, и разместить созданный объект на экране."}]},{"code":["class ViewController: UIViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание объекта карты","        let mapView = MapView(frame: CGRect(x: 0, y: 0,","                                            width: UIScreen.main.bounds.width,","                                            height: UIScreen.main.bounds.height),","                              configuration: configuration,","                              delegate: self)","        \/\/ Размещение карты на экране","        view.addSubview(mapView)","    }","}","","\/\/ Делегат карты","extension ViewController: MapViewDelegate {}"],"type":"codeListing","syntax":"swift"},{"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI-%D0%BF%D1%80%D0%BE%D0%B5%D0%BA%D1%82%D0%B5","type":"heading","level":4,"text":"Использование в SwiftUI-проекте"},{"type":"paragraph","inlineContent":[{"text":"Для использования карты в SwiftUI необходимо создать объект ","type":"text"},{"code":"MapView","type":"codeVoice"},{"text":" и передать его в структуру ","type":"text"},{"code":"Map","type":"codeVoice"},{"text":".","type":"text"}]},{"code":["\/\/ Делегат для MapView","class BaseMapViewDelegate: MapViewDelegate {}","","\/\/ View-модель экрана, где будет использоваться карта","final class ContentViewModel: ObservableObject {","    \/\/ Объект карты","    let mapView: MapView","    \/\/ Объект делегата карты","    private let mapViewDelegate: MapViewDelegate","    ","    init() {","        \/\/ Конфигурирование SDK","        MapsSDKConfigurator.setup(apiKey: \"...\")","        \/\/ Создание конфигурации карты","        let configuration = MapConfiguration(center: Coordinates(lng: 37.6156, lat: 55.7522), zoom: 10, predefinedStyle: .main)","        \/\/ Создание делегата карты","        let delegate = BaseMapViewDelegate()","        mapViewDelegate = delegate","        \/\/ Создание объекта карты","        mapView = MapView(configuration: configuration, delegate: delegate)","    }","}","","\/\/ Экран с картой","struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","","    var body: some View {","        Map(view: viewModel.mapView)","            .frame(maxWidth: .infinity, maxHeight: .infinity)","    }","}"],"type":"codeListing","syntax":"swift"}]}],"sections":[],"variants":[{"paths":["\/documentation\/mapsnativesdk\/startusing"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","references":{"https://dev.vk.com/ru/vkmaps/general-information/api-key":{"titleInlineContent":[{"type":"text","text":"портале"}],"identifier":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","url":"https:\/\/dev.vk.com\/ru\/vkmaps\/general-information\/api-key","title":"портале","type":"link"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/Lifecycle":{"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Lifecycle","abstract":[{"text":"Отслеживайте события, происходящие с картой, и программируйте реакцию на них.","type":"text"}],"kind":"article","url":"\/documentation\/mapsnativesdk\/lifecycle","role":"article","type":"topic","title":"Отслеживание событий карты"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/Styles":{"url":"\/documentation\/mapsnativesdk\/styles","kind":"article","role":"article","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/Styles","abstract":[{"type":"text","text":"Изменяйте внешний вид карты, рисуйте геометрические фигуры и размещайте маркеры."}],"title":"Оформление карты","type":"topic"},"doc://MapsNativeSDK/documentation/MapsNativeSDK/MapView":{"url":"\/documentation\/mapsnativesdk\/mapview","role":"symbol"