on = MapConfiguration(","    center: Coordinates(","        lng: 35.910974,","        lat: 56.859207","    ),","    zoom: 15,","    predefinedStyle: style,","    selectFeatures: .all,","    cameraMode: .earth",")","\/\/ Передаем конфигурацию и позже отдельно устанавливаем делегат","mapView = MapView(configuration: configuration)","mapView.delegate = self","","\/\/ ИЛИ","\/\/ Передаем конфигурацию и делегат одновременно","mapView = MapView(configuration: configuration, delegate: self)"]},{"type":"heading","anchor":"%D0%A8%D0%B0%D0%B3-3-%D0%98%D0%B7%D0%BC%D0%B5%D0%BD%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BC%D0%B5%D1%82%D0%BE%D0%B4%D0%BE%D0%B2-%D0%BF%D0%B5%D1%80%D0%B5%D0%BC%D0%B5%D1%89%D0%B5%D0%BD%D0%B8%D0%B5-%D0%BA%D0%B0%D0%BC%D0%B5%D1%80%D1%8B","text":"Шаг 3. Изменение методов перемещение камеры","level":3},{"type":"paragraph","inlineContent":[{"text":"Для перемещения камеры теперь необходимо обращаться к контроллеру ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/CameraController"},{"text":" через свойство ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/MapView\/camera"},{"text":". Ранее методы управления находились непосредственно в API класса ","type":"text"},{"code":"MapView","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для перемещения камеры используется методы группы "},{"type":"codeVoice","code":"flyTo"},{"type":"text","text":" и другие. Подробнее об это читайте в статье "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapsNativeSDK\/documentation\/MapsNativeSDK\/CameraMoving"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ БЫЛО","mapView.flyTo(Coordinates(lng: 33, lat: 55), animated: true, duration: 2)","","\/\/ СТАЛО","mapView.camera.flyTo(coordinates: .center(Coordinates(lng: 37.427278, lat: 55.756486)), ","         